NODE_ENV=development
PORT=8000
MONGODB_URI=mongodb://127.0.0.1:27017/rentfit
# Required in production (long random string)
# JWT_SECRET=
# Session length in seconds (default 604800 = 7 days)
# JWT_EXPIRES_SEC=604800
# HTTP-only auth cookie name (default rentfit_session)
# AUTH_COOKIE_NAME=rentfit_session
# OpenRouter (OpenAI-compatible): https://openrouter.ai/keys
# OPENROUTER_API_KEY=
# Must be the API origin (https://…), never the model id — use OPENROUTER_MODEL for that.
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Model id from https://openrouter.ai/models (default in code: openai/gpt-4o-mini)
# OPENROUTER_MODEL=openai/gpt-4o-mini
# Optional; recommended for OpenRouter rankings / attribution
# OPENROUTER_HTTP_REFERER=https://your-app.example
# OPENROUTER_APP_TITLE=Rentfit
# Comma-separated origins; omit to allow any origin (dev-friendly)
# CORS_ORIGIN=http://localhost:3000
