# Copy to `.env` and fill in values.
# Lines with `KEY=` (empty) are placeholders — remove a line if you want the app’s built-in default instead of an empty string.

# development | production | test
NODE_ENV=

# HTTP port (default 8000 if unset)
PORT=

# MongoDB connection string (default mongodb://127.0.0.1:27017/rentfit if unset)
MONGODB_URI=

# Comma-separated browser origins for credentialed CORS (e.g. https://your-app.vercel.app).
# Must include the exact frontend origin or login cookies won’t be accepted by the browser.
CORS_ORIGIN=

# lax | strict | none — default: lax in dev, none in production (cross-origin API + SPA).
AUTH_COOKIE_SAMESITE=

# Required when NODE_ENV=production
JWT_SECRET=

# Session lifetime in seconds (default 604800 = 7 days if unset or invalid)
JWT_EXPIRES_SEC=

# HttpOnly auth cookie name (default rentfit_session)
AUTH_COOKIE_NAME=

# OpenRouter — required when NODE_ENV=production
OPENROUTER_API_KEY=

# Model id (default openai/gpt-4o-mini)
OPENROUTER_MODEL=

# API base URL (default https://openrouter.ai/api/v1)
OPENROUTER_BASE_URL=

# Optional OpenRouter attribution headers
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=
