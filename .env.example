NODE_ENV=development
PORT=8000
MONGODB_URI=mongodb://127.0.0.1:27017/rentfit
# Required in production (long random string)
# JWT_SECRET=
# Session length in seconds (default 604800 = 7 days)
# JWT_EXPIRES_SEC=604800
# HTTP-only auth cookie name (default rentfit_session)
# AUTH_COOKIE_NAME=rentfit_session
# Ollama Cloud (OpenAI-compatible): https://ollama.com — create key under account settings
# OLLAMA_API_KEY=
# OLLAMA_BASE_URL=https://ollama.com/v1
# OLLAMA_MODEL=llama3.2
# Comma-separated origins; omit to allow any origin (dev-friendly)
# CORS_ORIGIN=http://localhost:3000
